@baseUrl = http://localhost:8080

### 1. Health check
GET {{baseUrl}}/actuator/health

### 2. Create automation
# @name createAutomation
POST {{baseUrl}}/api/automations
Content-Type: application/json

{
  "name": "Order support"
}

> {%
    client.global.set("automationId", response.body.id);
%}

### 3. Create workflow draft
# @name createWorkflow
POST {{baseUrl}}/api/automations/{{automationId}}/workflows
Content-Type: application/json

{
  "definition": {
    "nodes": [
      {
        "id": "start",
        "type": "START",
        "config": {}
      },
      {
        "id": "ask",
        "type": "QUESTION",
        "config": {
          "message": "Ban can ho tro gi?"
        }
      },
      {
        "id": "lookup",
        "type": "ACTION",
        "config": {
          "action": "ORDER_LOOKUP"
        }
      },
      {
        "id": "end",
        "type": "END",
        "config": {
          "message": "Da xu ly xong"
        }
      }
    ],
    "edges": [
      {
        "from": "start",
        "to": "ask",
        "matchType": "ALWAYS",
        "matchValue": ""
      },
      {
        "from": "ask",
        "to": "lookup",
        "matchType": "KEYWORD",
        "matchValue": "don hang"
      },
      {
        "from": "ask",
        "to": "end",
        "matchType": "FALLBACK",
        "matchValue": ""
      },
      {
        "from": "lookup",
        "to": "end",
        "matchType": "ALWAYS",
        "matchValue": ""
      }
    ]
  }
}

> {%
    client.global.set("workflowVersionId", response.body.id);
%}

### 4. Publish workflow
POST {{baseUrl}}/api/automations/{{automationId}}/workflows/{{workflowVersionId}}/publish

### 5. Send matching incoming message
# @name sendMessage
POST {{baseUrl}}/api/mock-chat/messages
X-Request-Id: request-demo-001
Content-Type: application/json

{
  "userId": "mock-user-001",
  "messageId": "msg-001",
  "automationId": "{{automationId}}",
  "text": "toi muon xem don hang A123"
}

> {%
    client.global.set("conversationId", response.body.conversationId);
    client.global.set("executionId", response.body.executionId);
    client.global.set("sessionId", response.body.sessionId);
%}

### 6. Send duplicate message_id
POST {{baseUrl}}/api/mock-chat/messages
X-Request-Id: request-demo-duplicate
Content-Type: application/json

{
  "userId": "mock-user-001",
  "conversationId": "{{conversationId}}",
  "messageId": "msg-001",
  "automationId": "{{automationId}}",
  "text": "toi muon xem don hang A123"
}

### 7. View history
GET {{baseUrl}}/api/mock-chat/conversations/{{conversationId}}/history

### 8. View current session
GET {{baseUrl}}/api/mock-chat/conversations/{{conversationId}}/session

### 9. View execution trace
GET {{baseUrl}}/api/mock-chat/conversations/{{conversationId}}/trace

### 10. View execution trace by execution id
GET {{baseUrl}}/api/mock-chat/executions/{{executionId}}/trace

### 11. View execution trace by session id
GET {{baseUrl}}/api/mock-chat/sessions/{{sessionId}}/trace

### 12. Send fallback message in another conversation
POST {{baseUrl}}/api/mock-chat/messages
X-Request-Id: request-demo-fallback
Content-Type: application/json

{
  "userId": "mock-user-002",
  "messageId": "msg-fallback-001",
  "automationId": "{{automationId}}",
  "text": "toi muon gap tong dai"
}
